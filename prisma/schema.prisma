generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CustomerProfile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  name        String?
  email       String?
  phone       String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders        Order[]
  carts         Cart[]

  @@map("customer_profiles")
}

model AdminProfile {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  name        String?
  email       String?
  role        String   @default("ADMIN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admin_profiles")
}

model Category {
  id            String   @id @default(cuid())
  nameSw        String
  nameEn        String
  slug          String   @unique
  descriptionSw String?
  descriptionEn String?
  image         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products       Product[]
  budgetRequests BudgetRequest[]

  @@map("categories")
}

model Supplier {
  id           String      @id @default(cuid())
  name         String
  phone        String?
  whatsapp     String?
  shopLocation String?
  notes        String?
  trustStatus  TrustStatus @default(PENDING_REVIEW)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  products       Product[]
  budgetRequests BudgetRequest[]

  @@index([trustStatus])
  @@map("suppliers")
}

model Product {
  id                String   @id @default(cuid())
  nameSw            String
  nameEn            String
  slug              String   @unique
  descriptionSw     String?
  descriptionEn     String?
  categoryId        String
  supplierId        String?
  sellingPrice      Float
  supplierCostPrice Float?
  discountPrice     Float?
  stockQuantity     Int      @default(0)
  sku               String?  @unique
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  isNewArrival      Boolean  @default(false)
  isBestDeal        Boolean  @default(false)
  adminNotes        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category  Category  @relation(fields: [categoryId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])

  images    ProductImage[]
  variants  ProductVariant[]
  cartItems CartItem[]
  orderItems OrderItem[]
  reviews   Review[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isNewArrival])
  @@index([isBestDeal])
  @@index([createdAt])
  @@index([isActive, isFeatured])
  @@index([isActive, isNewArrival])
  @@index([isActive, isBestDeal])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  path      String?
  altText   String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  name            String
  value           String
  stockQuantity   Int      @default(0)
  priceAdjustment Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Cart {
  id                String   @id @default(cuid())
  clerkUserId       String?
  customerProfileId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  customerProfileId String?
  clerkUserId       String?
  customerName      String
  customerPhone     String
  customerEmail     String?
  subtotal          Float
  deliveryFee       Float         @default(0)
  total             Float
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  adminNotes        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer  CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  items     OrderItem[]
  payment   Payment?
  delivery  Delivery?

  @@index([clerkUserId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([clerkUserId, createdAt])
  @@map("orders")
}

model OrderItem {
  id                       String  @id @default(cuid())
  orderId                  String
  productId                String
  productName              String
  quantity                 Int
  unitPrice                Float
  totalPrice               Float
  supplierCostPriceSnapshot Float?
  profitSnapshot           Float?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String        @unique
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  amount               Float
  transactionReference String?
  adminNotes           String?
  confirmedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Delivery {
  id            String         @id @default(cuid())
  orderId       String         @unique
  method        String?
  region        String?
  district      String?
  address       String?
  fee           Float          @default(0)
  status        DeliveryStatus @default(PENDING)
  riderName     String?
  riderPhone    String?
  trackingNote  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("deliveries")
}

model BudgetRequest {
  id                 String              @id @default(cuid())
  clerkUserId        String?
  fullName           String
  whatsappPhone      String
  productNeeded      String
  categoryId         String?
  budget             Float
  quantity           Int                 @default(1)
  location           String
  deliveryNeeded     Boolean             @default(false)
  extraDetails       String?
  referenceImage     String?
  referenceImagePath String?
  status             BudgetRequestStatus @default(NEW)
  assignedSupplierId String?
  quotedPrice        Float?
  adminNotes         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  category         Category?        @relation(fields: [categoryId], references: [id])
  assignedSupplier Supplier?        @relation(fields: [assignedSupplierId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([clerkUserId])
  @@map("budget_requests")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Review {
  id           String   @id @default(cuid())
  productId    String
  clerkUserId  String?
  customerName String
  rating       Int
  comment      String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// Enums
enum TrustStatus {
  TRUSTED
  PENDING_REVIEW
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  AWAITING_PAYMENT
  PAID
  PROCESSING
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  TIGO_PESA
  AIRTEL_MONEY
  HALOPESA
  CASH_ON_DELIVERY
  BANK_TRANSFER
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum BudgetRequestStatus {
  NEW
  REVIEWING
  SUPPLIER_FOUND
  QUOTATION_SENT
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_ORDER
  NEW_PAYMENT
  PAYMENT_CONFIRMED
  NEW_BUDGET_REQUEST
  LOW_STOCK
  DELIVERY_UPDATE
  CUSTOMER_MESSAGE
}
